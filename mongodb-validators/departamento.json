      },
      "nome": {
        "bsonType": "string",
        "description": "Nome completo do departamento"
      },
      "chefe": {
        "bsonType": "string",
        "description": "Matricula do chefe do departamento"
      },
      "orcamento": {
        "bsonType": "int",
