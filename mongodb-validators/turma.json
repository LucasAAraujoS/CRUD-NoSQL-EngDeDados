      "_id": {
        "bsonType": "objectId"
      },
      "id_turma": {
        "bsonType": "int",
        "description": "ID único da turma - PK"
      },
      "cod_disc": {
        "bsonType": "string",
        "description": "Código da disciplina vinculada (FK)"
      },
      "numero": {
        "bsonType": "int",
        "description": "Número da turma - FK"
      },
      "ano": {
        "bsonType": "int",
        "description": "Ano da turma - FK"
      },
      "semestre": {
        "enum": [
          1,
          2
        ],
        "description": "Semestre da turma"
      },
      "leciona": {
        "bsonType": "array",
        "required": [
          "mat_professor"
        ],
        "additionalProperties": false,
        "description": "Relação de turma com o conjunto leciona",
        "properties": {
          "mat_professor": {
            "bsonType": "int",
            "description": "matricula do professor que leciona a turma (FK)"
          }
        }
      }
    }
  }
}