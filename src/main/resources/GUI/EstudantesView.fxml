<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.EstudantesController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
            <children>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Gestão de Estudantes" textFill="#014da3">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Label text="Controle Central de Matrículas e Vínculos" textFill="#7f8c8d" />
                            </children>
                        </VBox>
                        <Button fx:id="btnNovo" mnemonicParsing="false" style="-fx-background-color: #014da3; -fx-text-fill: white; -fx-font-weight: bold;" text="[+] Adicionar Estudante" />
                        <Button fx:id="btnAtualizar" mnemonicParsing="false" style="-fx-background-color: #014da3; -fx-text-fill: white; -fx-font-weight: bold;" text="Atualizar Estudante" />
                        <Button fx:id="btnDeletar" mnemonicParsing="false" style="-fx-background-color: #014da3; -fx-text-fill: white; -fx-font-weight: bold;" text="Deletar Estudante" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <TextField fx:id="txtBusca" promptText="Pesquisar Estudante (Matrícula)..." HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnPesquisar" mnemonicParsing="false" prefWidth="100.0" text="Pesquisar" />
                    </children>
                </HBox>

                <HBox spacing="15.0" prefHeight="250.0" VBox.vgrow="ALWAYS">
                    <children>
                        <TableView fx:id="tabelaEstudantes" HBox.hgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colMatricula" style="-fx-alignment: CENTER;" text="Matrícula" />
                                <TableColumn fx:id="colMc" style="-fx-alignment: CENTER;" text="MC" />
                                <TableColumn fx:id="colAnoIngresso" style="-fx-alignment: CENTER;" text="Ano Ingresso" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </HBox>

                <TabPane prefHeight="220.0" tabClosingPolicy="UNAVAILABLE" style="-fx-border-color: #f39c12; -fx-border-width: 1.5; -fx-background-radius: 4; -fx-border-radius: 4;">
                    <tabs>

                        <Tab text="Vínculos">
                            <content>
                                <AnchorPane minHeight="0.0" minWidth="0.0">
                                    <children>
                                        <VBox spacing="8.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                                            <children>
                                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                                    <children>
                                                        <Button fx:id="btnAddVinculo" mnemonicParsing="false" style="-fx-background-color: #014da3; -fx-text-fill: white; -fx-font-weight: bold;" text="[+] Adicionar Vínculo" />
                                                        <Button fx:id="btnRemoverVinculo" mnemonicParsing="false" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold;" text="Remover Vínculo" />
                                                    </children>
                                                </HBox>
                                                <TableView fx:id="tabelaVinculos" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="colIdVinculo" style="-fx-alignment: CENTER;" text="Id Vínculo" />
                                                        <TableColumn fx:id="colDataEntrada" style="-fx-alignment: CENTER;" text="Data Entrada" />
                                                        <TableColumn fx:id="colDataSaida" style="-fx-alignment: CENTER;" text="Data Saída" />
                                                        <TableColumn fx:id="colStatusVinculo" style="-fx-alignment: CENTER;" text="Status" />
                                                        <TableColumn fx:id="colCursoVinculo" style="-fx-alignment: CENTER-LEFT;" text="Curso" />
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                    </columnResizePolicy>
                                                </TableView>
                                            </children>
                                        </VBox>
                                    </children>
                                </AnchorPane>
                            </content>
                        </Tab>

                        <Tab text="Usuário">
                            <content>
                                <AnchorPane minHeight="0.0" minWidth="0.0">
                                    <children>
                                        <TableView fx:id="tabelaUsuario" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                                            <columns>
                                                <TableColumn fx:id="colCpf" style="-fx-alignment: CENTER;" text="CPF" />
                                                <TableColumn fx:id="colNome" style="-fx-alignment: CENTER-LEFT;" text="Nome Completo" />
                                                <TableColumn fx:id="colLogin" style="-fx-alignment: CENTER;" text="Login" />
                                                <TableColumn fx:id="colDataNascimento" style="-fx-alignment: CENTER;" text="Data Nasc." />
                                                <TableColumn fx:id="colEmails" style="-fx-alignment: CENTER-LEFT;" text="E-mails" />
                                                <TableColumn fx:id="colTelefones" style="-fx-alignment: CENTER;" text="Telefones" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>
                                    </children>
                                </AnchorPane>
                            </content>
                        </Tab>
                    </tabs>
                </TabPane>

            </children>
        </VBox>
    </children>
</AnchorPane>